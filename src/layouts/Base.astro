---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
  canonicalURL?: string;
  schema?: Record<string, unknown>;
}

import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';

const { title, description = 'Terminal-grade thoughts on systems, Go, Linux, and the craft of building software.', image, type, canonicalURL, schema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} canonicalURL={canonicalURL} schema={schema} />
  </head>
  <body class="crt min-h-screen bg-terminal-bg text-terminal-text font-mono antialiased">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 lg:px-16">
      <header class="py-8 border-b border-terminal-border mb-8">
        <nav class="flex items-center justify-between">
          <a href="/" class="text-terminal-green glow-green text-lg font-bold hover:animate-glow transition-all">
            ~/yugal
          </a>
          <div class="flex gap-6 text-sm">
            <a href="/" class="text-terminal-dim hover:text-terminal-green transition-colors">home</a>
            <a href="/blog" class="text-terminal-dim hover:text-terminal-green transition-colors">blog</a>
            <a href="/about" class="text-terminal-dim hover:text-terminal-green transition-colors">about</a>
          </div>
        </nav>
      </header>

      <main class="min-h-[60vh]">
        <slot />
      </main>

      <footer class="py-8 mt-16 border-t border-terminal-border text-terminal-dim text-xs">
        <div class="flex justify-between items-center">
          <span>© {new Date().getFullYear()} yugal arora</span>
          <div class="flex gap-4">
            <a href="https://github.com/yugalarora" class="hover:text-terminal-green transition-colors">github</a>
            <a href="https://www.linkedin.com/in/yugal-arora-b0319958/" class="hover:text-terminal-green transition-colors">linkedin</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
