---
import Base from '../layouts/Base.astro';
import { generatePersonSchema } from '../lib/schema';

const schema = generatePersonSchema(
  'Yugal Arora',
  'https://yugalarora.com',
  'Systems Engineer',
  [
    'https://github.com/yugalarora',
    'https://www.linkedin.com/in/yugal-arora-b0319958/'
  ]
);
---

<Base title="About" schema={schema}>
  <div class="mb-6 text-terminal-dim text-sm">
    <span class="text-terminal-green">$</span> cat ./about.md
  </div>

  <h1 class="text-2xl font-bold text-terminal-green glow-green mb-6">About</h1>

  <div class="prose">
    <p>
      I'm Yugal — a systems engineer who builds developer tools, MCP servers,
      and infrastructure that doesn't wake you up at 3am.
    </p>

    <p>
      I think in Go, live in the terminal, and believe the best code is the code
      you don't have to write. When I'm not shipping, I'm probably exploring a
      massive open world — Ghost of Tsushima, Red Dead Redemption 2, or God of War
      are my kind of games.
    </p>

    <h2>What I work with</h2>
    <ul>
      <li>Go, Python, TypeScript</li>
      <li>MCP servers & agentic tooling</li>
      <li>AWS (ECS, Neptune, OpenSearch, Bedrock)</li>
      <li>Oracle Cloud, Kubernetes</li>
      <li>Graph databases & knowledge graphs</li>
      <li>Linux, containers, and everything in between</li>
    </ul>

    <h2>Get in touch</h2>
    <p>
      Find me on <a href="https://github.com/yugalarora">GitHub</a> or <a href="https://www.linkedin.com/in/yugal-arora-b0319958/">LinkedIn</a>.
    </p>
  </div>
</Base>
