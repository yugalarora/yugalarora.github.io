---
import Base from './Base.astro';
import { generateBlogPostingSchema } from '../lib/schema';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  image?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const { title, description, date, tags, image, ogImage, canonicalURL } = Astro.props;

const resolvedImage = ogImage ?? image ?? '/og-default.svg';

const postUrl = new URL(Astro.url.pathname, Astro.site).href;
const absoluteImage = new URL(resolvedImage, Astro.site).href;

const schema = generateBlogPostingSchema({
  title,
  description,
  datePublished: date.toISOString(),
  url: postUrl,
  image: absoluteImage,
  tags: tags.length > 0 ? tags : undefined,
});

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Base title={title} description={description} image={resolvedImage} type="article" canonicalURL={canonicalURL} schema={schema}>
  <article>
    <header class="mb-8">
      <p class="text-terminal-dim text-sm mb-2">
        <span class="text-terminal-green">$</span> cat ./posts/{formattedDate.replace(/\s/g, '-').toLowerCase()}
      </p>
      <h1 class="text-3xl font-bold text-terminal-green glow-green mb-3">{title}</h1>
      <p class="text-terminal-dim text-sm mb-4">{description}</p>
      <div class="flex items-center gap-4 text-xs text-terminal-dim">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <div class="flex gap-2">
          {tags.map((tag) => (
            <span class="text-terminal-cyan">#{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
